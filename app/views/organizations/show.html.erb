<% content_for :title, "#{@organization.name} · Tabled" %>

<article class="binder-page w-full">
  <div class="document-meta">
    <span>Club workspace</span>
    <span><%= @membership.role.humanize %> access</span>
    <span>Current semester · <%= current_semester_label %></span>
  </div>

  <header class="border-b-2 border-ink/20 px-5 py-6 sm:px-8">
    <% if @organization.archived? %>
      <div class="mb-5 border-l-4 border-brick bg-brick-pale px-4 py-3 text-sm leading-6 text-ink">
        <p class="font-bold">This organization is archived.</p>
        <p>Records are still available, but new activity is closed until an owner restores the workspace.</p>
      </div>
    <% end %>
    <div class="flex flex-wrap items-start justify-between gap-5">
      <div>
        <p class="eyebrow">This semester</p>
        <h1 class="mt-2 text-3xl font-semibold sm:text-4xl"><%= @organization.name %></h1>
        <% if @organization.description.present? %>
          <p class="mt-3 max-w-3xl leading-7 text-ink-soft"><%= @organization.description %></p>
        <% elsif OrganizationPolicy.new(current_user, @organization).manage? %>
          <p class="mt-3 max-w-3xl leading-7 text-ink-soft">This organization does not have a description yet. <%= link_to "Add one in organization details", edit_organization_path(@organization), class: "text-link" %>.</p>
        <% else %>
          <p class="mt-3 max-w-3xl leading-7 text-ink-soft">This organization does not have a description yet. An owner or officer can add one.</p>
        <% end %>
        <% if @organization.contact_email.present? || @organization.website_url.present? || @organization.meeting_note.present? || @organization.current_semester_label.present? %>
          <dl class="mt-5 grid max-w-3xl gap-3 text-sm leading-6 text-ink-soft sm:grid-cols-2">
            <% if @organization.current_semester_label.present? %>
              <div><dt class="font-bold text-moss-dark">Current semester</dt><dd><%= @organization.current_semester_label %></dd></div>
            <% end %>
            <% if @organization.meeting_note.present? %>
              <div><dt class="font-bold text-moss-dark">Meeting note</dt><dd><%= @organization.meeting_note %></dd></div>
            <% end %>
            <% if @organization.contact_email.present? %>
              <div><dt class="font-bold text-moss-dark">Contact</dt><dd><%= mail_to @organization.contact_email, @organization.contact_email, class: "text-link" %></dd></div>
            <% end %>
            <% if @organization.website_url.present? %>
              <div><dt class="font-bold text-moss-dark">Website</dt><dd><%= link_to @organization.website_url, @organization.website_url, class: "text-link" %></dd></div>
            <% end %>
          </dl>
        <% end %>
      </div>
      <nav aria-label="Organization sections" class="flex max-w-full flex-wrap items-center gap-x-3 gap-y-2 text-sm sm:justify-end">
        <%= link_to "Bulletin", organization_announcements_path(@organization), class: "text-link whitespace-nowrap" %>
        <%= link_to "Gatherings", organization_events_path(@organization), class: "text-link whitespace-nowrap" %>
        <%= link_to "Member roster", organization_members_path(@organization), class: "text-link whitespace-nowrap" %>
        <% unless @can_view_reports || @can_view_activity %>
          <%= link_to "Communication preferences", organization_communication_preferences_path(@organization), class: "text-link whitespace-nowrap" %>
        <% end %>
        <% if @can_view_reports %>
          <%= link_to "Semester report", organization_reports_path(@organization), class: "text-link whitespace-nowrap" %>
        <% end %>
        <% if @can_view_activity %>
          <%= link_to "Log book", organization_log_book_path(@organization), class: "text-link whitespace-nowrap" %>
        <% end %>
        <span class="role-tag shrink-0"><%= @membership.role.humanize %></span>
      </nav>
    </div>
  </header>

  <div class="lg:grid lg:grid-cols-[1fr_18rem]">
    <div class="divide-y divide-rule lg:border-r lg:border-rule">
      <section id="around-the-table" class="workspace-section">
        <div class="workspace-section-heading">
          <p class="eyebrow">Members</p>
          <h2 class="mt-1 text-2xl font-semibold">Around the table</h2>
        </div>

        <div class="mt-7">
          <h3 class="text-sm font-bold"><%= link_to "Member roster →", organization_members_path(@organization), class: "text-link" %></h3>
          <div class="mt-3 divide-y divide-rule/70 border-y border-rule">
            <% @dashboard_memberships.each do |membership| %>
              <div class="member-row">
                <span class="min-w-0 font-semibold"><%= membership.user.name %></span>
                <span class="role-tag"><%= membership.role.humanize %></span>
              </div>
            <% end %>
          </div>
          <%= render "shared/pagination", paginator: @member_paginator, anchor: "around-the-table" %>
        </div>
      </section>

      <section class="workspace-section">
        <div>
          <p class="eyebrow">Events</p>
          <h2 class="mt-1 text-2xl font-semibold">Upcoming gatherings</h2>
        </div>

        <% if @upcoming_events.any? %>
          <div class="mt-5 divide-y divide-rule border-y border-rule">
            <% @upcoming_events.each do |event| %>
              <article class="event-row">
                <time class="event-date" datetime="<%= event.starts_at.iso8601 %>">
                  <span class="text-xs font-bold text-moss-dark"><%= event.starts_at.strftime("%b") %></span>
                  <span class="font-serif text-2xl font-semibold leading-none"><%= event.starts_at.day %></span>
                </time>
                <div class="min-w-0 flex-1">
                  <h3 class="text-lg font-semibold"><%= link_to event.title, organization_event_path(@organization, event), class: "text-link" %></h3>
                  <p class="mt-1 text-sm text-ink-soft"><%= event.starts_at.strftime("%A at %-I:%M %p") %><% if event.location.present? %> · <%= event.location %><% end %></p>
                  <p class="mt-2 text-xs font-semibold text-ink-soft"><%= pluralize(event.attending_count, "member") %> attending<% if event.capacity.present? %> · <%= event.capacity %> spots<% end %></p>
                </div>
                <% if (rsvp = @dashboard_rsvps[event.id]) %><span class="role-tag"><%= rsvp.status.humanize %></span><% end %>
              </article>
            <% end %>
          </div>
          <p class="mt-4 text-sm font-bold"><%= link_to "See all gatherings →", organization_events_path(@organization), class: "text-link" %></p>
        <% else %>
          <div class="mt-5 border-l-4 border-amber bg-amber-pale/45 px-4 py-3">
            <p class="font-bold">No gatherings yet.</p>
            <p class="mt-1 text-sm text-ink-soft">Add the first meeting when your calendar is ready.</p>
          </div>
        <% end %>
      </section>

      <section class="workspace-section">
        <p class="eyebrow">Attendance</p>
        <h2 class="mt-1 text-2xl font-semibold">Recent roll call</h2>
        <% if @recent_attendance_events.any? %>
          <div class="mt-5 divide-y divide-rule border-y border-rule">
            <% @recent_attendance_events.each do |event| %>
              <article class="event-row">
                <time class="event-date opacity-75" datetime="<%= event.starts_at.iso8601 %>">
                  <span class="text-xs font-bold text-moss-dark"><%= event.starts_at.strftime("%b") %></span>
                  <span class="font-serif text-2xl font-semibold leading-none"><%= event.starts_at.day %></span>
                </time>
                <div class="min-w-0 flex-1">
                  <h3 class="font-semibold"><%= link_to event.title, organization_event_path(@organization, event), class: "text-link" %></h3>
                  <p class="mt-1 text-sm text-ink-soft"><%= pluralize(event.attendance_records.count { |record| record.present? || record.late? }, "member") %> present or late · attendance recorded</p>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <div class="ruled-list mt-5 min-h-20 border-t border-rule py-2 text-sm text-ink-soft">
            <p class="px-2 py-1">No roll calls yet. Check-in history will appear here after events begin.</p>
          </div>
        <% end %>
      </section>
    </div>

    <aside class="border-t-2 border-ink/15 bg-paper-deep/45 lg:border-t-0">
      <section class="border-b border-rule p-5 sm:p-6">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="eyebrow text-amber">Announcements</p>
            <h2 class="mt-1 text-2xl font-semibold">Bulletin</h2>
          </div>
          <%= link_to "View all", organization_announcements_path(@organization), class: "text-link text-xs" %>
        </div>
        <% if @bulletin_announcement %>
          <article class="mt-4 border border-rule bg-[#fff8de] p-4 shadow-[2px_2px_0_rgba(166,111,45,0.16)] <%= "border-t-4 border-t-amber" if @bulletin_announcement.pinned? %>">
            <% if @bulletin_announcement.pinned? %><p class="eyebrow text-amber">Pinned</p><% end %>
            <h3 class="mt-1 font-semibold"><%= link_to @bulletin_announcement.title, organization_announcement_path(@organization, @bulletin_announcement), class: "text-link" %></h3>
            <p class="mt-2 line-clamp-4 text-sm leading-6 text-ink-soft"><%= @bulletin_announcement.body %></p>
            <p class="mt-3 text-xs text-ink-soft">Posted by <%= @bulletin_announcement.author.name %> · <%= @bulletin_announcement.audience_label %></p>
          </article>
        <% else %>
          <div class="mt-4 border border-rule bg-[#fff8de] p-4 shadow-[2px_2px_0_rgba(166,111,45,0.16)]">
            <p class="font-bold">The board is clear.</p>
            <p class="mt-1 text-sm leading-6 text-ink-soft">Announcements will be pinned here when officers have something to share.</p>
          </div>
        <% end %>
      </section>

      <section class="border-b border-rule p-5 sm:p-6">
        <p class="eyebrow text-brick">Active notes</p>
        <h2 class="mt-1 text-xl font-semibold">What needs attention</h2>
        <% if @attendance_follow_ups&.any? %>
          <ul class="mt-4 divide-y divide-rule border-y border-rule text-sm">
            <% @attendance_follow_ups.each do |kind, event| %>
              <li class="py-3 leading-6">
                <% if kind == :check_in_open %>
                  Check-in is open for <%= link_to event.title, organization_event_path(@organization, event), class: "text-link font-bold" %>.
                <% else %>
                  Attendance still needs marking for <%= link_to event.title, organization_event_attendance_path(@organization, event), class: "text-link font-bold" %>.
                <% end %>
              </li>
            <% end %>
          </ul>
        <% elsif @attendance_follow_ups %>
          <p class="mt-3 text-sm leading-6 text-ink-soft">All recent gatherings are recorded.</p>
        <% else %>
          <p class="mt-3 text-sm leading-6 text-ink-soft">Nothing needs follow-up right now.</p>
        <% end %>
      </section>

      <% if @can_view_reports %>
        <section class="border-b border-rule p-5 sm:p-6">
          <p class="eyebrow text-moss-dark">Officer records</p>
          <h2 class="mt-1 text-xl font-semibold">Semester report</h2>
          <p class="mt-3 text-sm leading-6 text-ink-soft"><%= pluralize(@semester_report.total_members, "member") %> · <%= pluralize(@semester_report.events_with_attendance_recorded, "gathering") %> recorded</p>
          <% if @events_needing_attendance_count.positive? %>
            <p class="mt-2 text-sm font-bold text-brick"><%= pluralize(@events_needing_attendance_count, "event") %> still need attendance.</p>
          <% else %>
            <p class="mt-2 text-sm text-ink-soft">Attendance records are up to date.</p>
          <% end %>
          <p class="mt-4 text-sm font-bold"><%= link_to "Open semester report →", organization_reports_path(@organization), class: "text-link" %></p>
        </section>
      <% end %>

      <% if @can_view_activity %>
        <section class="p-5 sm:p-6">
          <p class="eyebrow">Log book</p>
          <h2 class="mt-1 text-xl font-semibold">Recent activity</h2>
          <% if @recent_activity_entries&.any? %>
            <ul class="mt-4 divide-y divide-rule border-y border-rule text-sm">
              <% @recent_activity_entries.each do |entry| %>
                <li class="py-3 leading-6">
                  <p class="font-semibold text-ink"><%= entry.summary %></p>
                  <p class="mt-1 text-xs text-ink-soft">
                    <%= entry.category_label %> · <%= entry.occurred_at.to_fs(:short) %>
                    <% if entry.actor %>
                      · Updated by <%= entry.actor.name %>
                    <% end %>
                  </p>
                </li>
              <% end %>
            </ul>
            <p class="mt-4 text-sm font-bold"><%= link_to "Open log book →", organization_log_book_path(@organization), class: "text-link" %></p>
          <% else %>
            <p class="mt-3 text-sm leading-6 text-ink-soft">No notes in the log book yet.</p>
          <% end %>
        </section>
      <% end %>

      <% if @can_manage_members %>
        <section class="border-t border-rule p-5 sm:p-6">
          <p class="eyebrow text-moss-dark">Administration</p>
          <h2 class="mt-1 text-xl font-semibold">Workspace settings</h2>
          <p class="mt-3 text-sm leading-6 text-ink-soft">Update organization details, ownership, and archive options.</p>
          <p class="mt-4 text-sm font-bold"><%= link_to "Open organization settings →", edit_organization_path(@organization), class: "text-link" %></p>
        </section>
      <% end %>

      <section class="border-t border-rule p-5 sm:p-6">
        <details class="group">
          <summary class="cursor-pointer list-none text-sm font-bold text-ink-soft underline decoration-moss/30 underline-offset-4 focus:outline-2 focus:outline-moss/50">
            Membership options
          </summary>
          <div class="mt-4 space-y-4 border-l-4 border-brick/50 bg-paper px-4 py-3">
            <div>
              <p class="eyebrow text-moss-dark">Your preferences</p>
              <p class="mt-2 text-sm leading-6 text-ink-soft">Choose which organization emails you want to receive.</p>
              <p class="mt-3 text-sm font-bold"><%= link_to "Communication preferences →", organization_communication_preferences_path(@organization), class: "text-link" %></p>
            </div>
            <div class="border-t border-rule pt-4">
            <p class="eyebrow text-brick">Leave organization</p>
            <p class="mt-2 text-sm leading-6 text-ink-soft">You’ll lose access to this organization’s roster, events, announcements, and reports.</p>
            <%= button_to "Leave organization", organization_leave_path(@organization), method: :delete,
              class: "mt-4 text-sm font-bold text-brick underline decoration-brick/40 underline-offset-4",
              form: { data: { turbo_confirm: "Leave #{@organization.name}? You’ll lose access to this organization." } } %>
            </div>
          </div>
        </details>
      </section>
    </aside>
  </div>
</article>
