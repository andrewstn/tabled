<% content_for :title, "#{@organization.name} · Tabled" %>

<div class="w-full space-y-6">
  <header class="border-b-2 border-moss/30 pb-7">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="eyebrow"><%= @membership.role.humanize %> · organization workspace</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl"><%= @organization.name %></h1>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-ink-soft"><%= @organization.description.presence || "Your group has a place at the table. Add a short description whenever you’re ready." %></p>
      </div>
      <span class="rounded-md border border-rule bg-paper-deep px-3 py-2 text-sm font-semibold text-ink-soft"><%= @membership.role.humanize %></span>
    </div>
  </header>

  <div class="grid gap-6 lg:grid-cols-[1.35fr_0.65fr]">
    <div class="space-y-6">
      <section class="paper-panel overflow-hidden">
        <div class="border-b border-rule bg-paper-deep/60 px-6 py-4">
          <p class="eyebrow">Directory</p>
          <h2 class="mt-1 text-2xl font-semibold">Around the table</h2>
        </div>
        <div class="flex items-center justify-between gap-5 p-6">
          <div>
            <p class="font-semibold"><%= pluralize(@organization.memberships.count, "member") %> have a seat</p>
            <p class="mt-1 text-sm text-ink-soft">The member directory will live here.</p>
          </div>
          <span class="rounded-full border border-moss/30 bg-moss/10 px-3 py-1 text-sm font-semibold text-moss-dark">Members</span>
        </div>
      </section>

      <section class="paper-panel p-6">
        <p class="eyebrow">Events</p>
        <h2 class="mt-1 text-2xl font-semibold">Upcoming gatherings</h2>
        <div class="mt-5 border-l-4 border-amber bg-paper-deep/50 px-4 py-3">
          <p class="font-semibold">Nothing is on the calendar yet.</p>
          <p class="mt-1 text-sm text-ink-soft">Once the group plans its next meeting, it’ll be pinned here.</p>
        </div>
      </section>

      <section class="paper-panel p-6">
        <p class="eyebrow">Attendance</p>
        <h2 class="mt-1 text-2xl font-semibold">Recent roll call</h2>
        <p class="mt-4 text-ink-soft">No check-ins yet. The first sign-in sheet is waiting for an event.</p>
      </section>
    </div>

    <aside class="space-y-6">
      <section class="border border-rule bg-[#fff8df] p-6 shadow-[3px_4px_0_rgba(179,122,54,0.15)]">
        <p class="eyebrow text-amber">Announcements</p>
        <h2 class="mt-1 text-2xl font-semibold">Bulletin</h2>
        <p class="mt-4 leading-7 text-ink-soft">The board is clear. Organization announcements will be posted here.</p>
      </section>

      <section class="border-t-4 border-brick bg-[#fffaf0] p-6 shadow-sm">
        <p class="eyebrow text-brick">Activity</p>
        <h2 class="mt-1 text-xl font-semibold">What needs attention</h2>
        <p class="mt-3 text-sm leading-6 text-ink-soft">Everything is tidy for now. New member notes and organization activity will collect here.</p>
      </section>
    </aside>
  </div>
</div>
