<% content_for :title, "#{@organization.name} · Tabled" %>

<article class="binder-page w-full">
  <div class="document-meta">
    <span>Club workspace</span>
    <span><%= @membership.role.humanize %> access</span>
    <span>Current semester</span>
  </div>

  <header class="border-b-2 border-ink/20 px-6 py-6 sm:px-9">
    <div class="flex flex-wrap items-start justify-between gap-5">
      <div>
        <p class="eyebrow">This semester</p>
        <h1 class="mt-2 text-3xl font-semibold sm:text-4xl"><%= @organization.name %></h1>
        <% if @organization.description.present? %>
          <p class="mt-3 max-w-3xl leading-7 text-ink-soft"><%= @organization.description %></p>
        <% elsif OrganizationPolicy.new(current_user, @organization).manage? %>
          <p class="mt-3 max-w-3xl leading-7 text-ink-soft">This organization does not have a description yet. <%= link_to "Add one in organization details", edit_organization_path(@organization), class: "text-link" %>.</p>
        <% else %>
          <p class="mt-3 max-w-3xl leading-7 text-ink-soft">This organization does not have a description yet. An owner or officer can add one.</p>
        <% end %>
      </div>
      <div class="flex items-center gap-3">
        <% if OrganizationPolicy.new(current_user, @organization).manage? %>
          <%= link_to "Edit organization", edit_organization_path(@organization), class: "text-link text-sm" %>
        <% end %>
        <span class="desk-label"><%= @membership.role.humanize %></span>
      </div>
    </div>
  </header>

  <div class="lg:grid lg:grid-cols-[1fr_18rem]">
    <div class="divide-y divide-rule lg:border-r lg:border-rule">
      <section class="p-6 sm:p-9">
        <div class="flex flex-wrap items-end justify-between gap-3 border-b border-rule pb-2">
          <div>
            <p class="eyebrow">Members</p>
            <h2 class="mt-1 text-2xl font-semibold">Around the table</h2>
          </div>
          <p class="text-sm font-bold text-ink-soft"><%= pluralize(@organization.memberships.count, "member") %></p>
        </div>

        <div class="mt-5">
          <h3 class="text-xs font-bold uppercase tracking-[0.12em] text-ink-soft">Member roster</h3>
          <div class="ruled-list mt-2 border-t border-rule">
            <% @organization.memberships.includes(:user).order(:role).each do |membership| %>
              <div class="flex min-h-[2.15rem] items-center justify-between gap-4 px-2 py-1.5 text-sm">
                <span class="font-semibold"><%= membership.user.name %></span>
                <span class="text-xs uppercase tracking-wider text-ink-soft"><%= membership.role %></span>
              </div>
            <% end %>
          </div>
        </div>
      </section>

      <section class="p-6 sm:p-9">
        <p class="eyebrow">Events</p>
        <h2 class="mt-1 text-2xl font-semibold">Upcoming gatherings</h2>
        <div class="mt-5 border-l-4 border-amber bg-amber-pale/45 px-4 py-3">
          <p class="font-bold">No gatherings yet.</p>
          <p class="mt-1 text-sm text-ink-soft">The first meeting will appear here when the organization calendar is ready.</p>
        </div>
      </section>

      <section class="p-6 sm:p-9">
        <p class="eyebrow">Attendance</p>
        <h2 class="mt-1 text-2xl font-semibold">Recent roll call</h2>
        <div class="ruled-list mt-5 min-h-20 border-t border-rule py-2 text-sm text-ink-soft">
          <p class="px-2 py-1">No roll calls yet. Check-in history will appear here after events begin.</p>
        </div>
      </section>
    </div>

    <aside class="bg-paper-deep/45">
      <section class="border-b border-rule p-6">
        <p class="eyebrow text-amber">Announcements</p>
        <h2 class="mt-1 text-2xl font-semibold">Bulletin</h2>
        <div class="mt-4 border border-rule bg-[#fff8de] p-4 shadow-[2px_2px_0_rgba(166,111,45,0.16)]">
          <p class="text-sm leading-6 text-ink-soft">The board is clear. Announcements will be pinned here.</p>
        </div>
      </section>

      <section class="border-b border-rule p-6">
        <p class="eyebrow text-brick">Officer notes</p>
        <h2 class="mt-1 text-xl font-semibold">What needs attention</h2>
        <p class="mt-3 text-sm leading-6 text-ink-soft">Nothing needs follow-up right now.</p>
      </section>

      <section class="p-6">
        <p class="eyebrow">Log book</p>
        <h2 class="mt-1 text-xl font-semibold">Recent activity</h2>
        <p class="mt-3 text-sm leading-6 text-ink-soft">No notes in the log book yet.</p>
      </section>
    </aside>
  </div>
</article>
