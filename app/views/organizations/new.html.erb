<% content_for :title, "Start an organization · Tabled" %>

<div class="paper-panel w-full max-w-2xl p-7 sm:p-10">
  <h1 class="auth-title">Add an organization</h1>
  <p class="auth-copy">Enter the name and short description members should see. You’ll start as the organization owner.</p>

  <%= form_with model: @organization, class: "mt-8 space-y-6" do |form| %>
    <%= render "shared/form_errors", record: @organization %>
    <div>
      <%= form.label :name, "Organization name", class: "form-label" %>
      <%= form.text_field :name, required: true, autofocus: true, maxlength: Organization::NAME_MAX_LENGTH, placeholder: "Buckeye Film Society", class: "form-input" %>
      <p class="mt-2 text-sm text-ink-soft">Use the same name that appears on campus listings, flyers, and meeting notices. <%= Organization::NAME_MAX_LENGTH %> characters maximum.</p>
    </div>
    <div>
      <%= form.label :description, "Organization description", class: "form-label" %>
      <%= form.text_area :description, rows: 5, maxlength: Organization::DESCRIPTION_MAX_LENGTH, placeholder: "What does the organization do, and who is it for?", class: "form-input resize-y" %>
      <p class="mt-2 text-sm text-ink-soft">Keep this readable for members. <%= Organization::DESCRIPTION_MAX_LENGTH %> characters maximum.</p>
    </div>
    <div class="flex flex-wrap items-center gap-4">
      <%= form.submit "Create organization", class: "button-primary" %>
      <%= link_to "Back to organizations", root_path, class: "text-link" %>
    </div>
  <% end %>
</div>
