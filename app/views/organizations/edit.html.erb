<% content_for :title, "Organization settings · #{@organization.name} · Tabled" %>

<article class="binder-page w-full max-w-3xl">
  <div class="document-meta">
    <span><%= link_to @organization.name, organization_path(@organization), class: "text-link" %></span>
    <span>Officer settings</span>
  </div>

  <header class="border-b-2 border-ink/20 px-5 py-6 sm:px-8">
    <h1 class="mt-2 text-3xl font-semibold">Organization settings</h1>
    <p class="mt-2 max-w-2xl text-sm leading-6 text-ink-soft">Update the details members see across this organization. These settings help keep the workspace clear for current and future officers.</p>
  </header>

  <section class="p-5 sm:p-8">
    <%= form_with model: @organization, class: "space-y-6" do |form| %>
      <%= render "shared/form_errors", record: @organization %>
      <div>
        <%= form.label :name, "Organization name", class: "form-label" %>
        <%= form.text_field :name, required: true, class: "form-input" %>
      </div>
      <div>
        <%= form.label :description, "Organization description", class: "form-label" %>
        <%= form.text_area :description, rows: 5, maxlength: 1000, class: "form-input resize-y" %>
      </div>
      <div>
        <%= form.label :contact_email, "Contact email", class: "form-label" %>
        <%= form.email_field :contact_email, autocomplete: "email", class: "form-input" %>
      </div>
      <div>
        <%= form.label :website_url, "Website or public link", class: "form-label" %>
        <%= form.url_field :website_url, placeholder: "https://example.edu/club", class: "form-input" %>
      </div>
      <div>
        <%= form.label :meeting_note, "Usual meeting location or note", class: "form-label" %>
        <%= form.text_field :meeting_note, maxlength: 255, placeholder: "Student Union room 214 on Fridays", class: "form-input" %>
      </div>
      <div>
        <%= form.label :current_semester_label, "Current semester label", class: "form-label" %>
        <%= form.text_field :current_semester_label, maxlength: 80, placeholder: current_semester_label, class: "form-input" %>
      </div>

      <div class="border-l-4 border-amber bg-amber-pale/35 px-4 py-3 text-sm leading-6 text-ink-soft">
        <p class="font-bold text-ink">Workspace address</p>
        <p class="mt-1"><code><%= @organization.slug %></code></p>
        <p class="mt-1">The organization slug is visible here but not editable yet, so existing links stay stable.</p>
      </div>

      <div class="flex flex-wrap items-center gap-4 border-t border-rule pt-5">
        <%= form.submit "Save organization details", class: "button-primary" %>
        <%= link_to "Cancel", organization_path(@organization), class: "button-secondary" %>
      </div>
    <% end %>
  </section>

  <% if OrganizationPolicy.new(current_user, @organization).transfer_ownership? %>
    <section class="border-t border-rule p-5 sm:p-8" aria-labelledby="administrative-actions">
      <div class="workspace-section-heading">
        <p class="eyebrow text-brick">Owner settings</p>
        <h2 id="administrative-actions" class="mt-1 text-2xl font-semibold">Administrative actions</h2>
      </div>

      <div class="mt-6 border-l-4 border-amber bg-amber-pale/35 px-4 py-4">
        <h3 class="font-bold">Transfer ownership</h3>
        <p class="mt-1 text-sm leading-6 text-ink-soft">Choose another member to make an owner. This does not remove your own owner access.</p>
        <%= form_with url: organization_ownership_transfer_path(@organization), method: :patch, class: "mt-4 flex flex-wrap items-end gap-3" do |form| %>
          <div class="min-w-48 flex-1">
            <%= form.label :membership_id, "Member", class: "form-label" %>
            <%= form.collection_select :membership_id, @owner_transfer_memberships, :id, ->(membership) { "#{membership.user.name} · #{membership.role.humanize}" }, { prompt: "Choose a member" }, class: "form-input" %>
          </div>
          <%= form.submit "Transfer ownership", class: "button-secondary" %>
        <% end %>
      </div>

      <div class="mt-6 border-l-4 border-brick bg-brick-pale px-4 py-4">
        <% if @organization.archived? %>
          <h3 class="font-bold">Restore organization</h3>
          <p class="mt-1 text-sm leading-6 text-ink-soft">Restoring reopens the workspace for new events, announcements, invitations, and roster imports.</p>
          <%= button_to "Restore organization", organization_archive_path(@organization), method: :delete, class: "button-secondary mt-4" %>
        <% else %>
          <h3 class="font-bold">Archive organization</h3>
          <p class="mt-1 text-sm leading-6 text-ink-soft">Archiving keeps the records but closes the workspace for new activity.</p>
          <%= button_to "Archive organization", organization_archive_path(@organization), method: :patch,
            class: "mt-4 text-sm font-bold text-brick underline decoration-brick/40 underline-offset-4",
            form: { data: { turbo_confirm: "Archive #{@organization.name}? Records stay available, but new activity will be closed." } } %>
        <% end %>
      </div>
    </section>
  <% end %>
</article>
