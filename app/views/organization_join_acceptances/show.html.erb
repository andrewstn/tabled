<% content_for :title, @join_link ? "Join #{@join_link.organization.name} · Tabled" : "Recruitment link unavailable · Tabled" %>

<article class="binder-page mx-auto w-full max-w-3xl">
  <div class="document-meta">
    <span>Recruitment table</span>
    <span>Tabled member book</span>
  </div>

  <header class="border-b-2 border-ink/20 px-5 py-8 text-center sm:px-10 sm:py-12">
    <p class="eyebrow text-brick">Around the table</p>
    <% if @join_link %>
      <h1 class="mt-3 text-3xl font-semibold sm:text-5xl">Join <%= @join_link.organization.name %></h1>
      <p class="mx-auto mt-4 max-w-xl leading-7 text-ink-soft"><%= @join_link.label %> · You’re joining as a member.</p>
    <% else %>
      <h1 class="mt-3 text-3xl font-semibold sm:text-5xl">Recruitment link unavailable</h1>
      <p class="mx-auto mt-4 max-w-xl leading-7 text-ink-soft">This link could not be found. Ask an organization officer for a current link.</p>
    <% end %>
  </header>

  <% if @join_link %>
    <section class="p-5 sm:p-8">
      <% if @existing_membership %>
        <div class="border-l-4 border-moss bg-moss-pale/40 px-5 py-4">
          <h2 class="text-xl font-semibold">You’re already around the table.</h2>
          <p class="mt-2 text-sm text-ink-soft">Your name is already on the <%= @join_link.organization.name %> member roster.</p>
          <%= link_to "Open organization", organization_path(@join_link.organization), class: "button-primary mt-4" %>
        </div>
      <% elsif !@join_link.active? %>
        <%= render "unavailable", heading: "This recruitment link is no longer active.", detail: "Ask an organization officer for a current link." %>
      <% elsif @join_link.expired? %>
        <%= render "unavailable", heading: "This recruitment link has expired.", detail: "The recruitment table may have closed, but an officer can share a new link." %>
      <% elsif @join_link.full? %>
        <%= render "unavailable", heading: "This recruitment link has reached its limit.", detail: "Ask an organization officer whether another link is available." %>
      <% elsif authenticated? %>
        <div class="text-center">
          <h2 class="text-2xl font-semibold">Save your place on the roster</h2>
          <p class="mx-auto mt-3 max-w-lg text-sm leading-6 text-ink-soft">You’re signed in as <strong class="text-ink"><%= current_user.name %></strong>. The final join button will add you as a member.</p>
          <p class="mt-5 text-sm font-bold text-ink-soft">Ready to join</p>
        </div>
      <% else %>
        <div class="text-center">
          <h2 class="text-2xl font-semibold">Use your account to save your place</h2>
          <p class="mx-auto mt-3 max-w-lg text-sm leading-6 text-ink-soft">Create an account or sign in to join this organization.</p>
          <div class="mt-6 flex flex-wrap justify-center gap-3">
            <%= link_to "Create an account", new_user_path(join_token: params[:token]), class: "button-primary" %>
            <%= link_to "Sign in", new_session_path, class: "button-secondary" %>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>
</article>
