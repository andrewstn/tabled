<% content_for :title, "Attendance · #{@event.title} · Tabled" %>

<article class="binder-page w-full">
  <div class="document-meta">
    <span><%= link_to @organization.name, organization_path(@organization), class: "text-link" %></span>
    <span><%= link_to @event.title, organization_event_path(@organization, @event), class: "text-link" %></span>
    <span>Attendance sheet</span>
  </div>

  <header class="border-b-2 border-ink/20 px-5 py-6 sm:px-8">
    <div class="flex flex-wrap items-end justify-between gap-5">
      <div>
        <p class="eyebrow">Digital sign-in sheet · <%= @event.starts_at.strftime("%A, %B %-d at %-I:%M %p") %></p>
        <h1 class="mt-2 text-3xl font-semibold sm:text-4xl">Attendance sheet</h1>
        <p class="mt-3 max-w-2xl leading-7 text-ink-soft">Mark who made it to <strong class="text-ink"><%= @event.title %></strong>. RSVPs show who planned to come; attendance records who was there.</p>
      </div>
      <%= link_to "Export attendance CSV", organization_event_attendance_path(@organization, @event, request.query_parameters.merge(format: :csv, page: nil)), class: "button-secondary" %>
    </div>
  </header>

  <section class="border-b border-rule px-5 py-5 sm:px-8" aria-label="Attendance filters">
    <%= form_with url: organization_event_attendance_path(@organization, @event), method: :get, class: "grid gap-4 md:grid-cols-[1fr_10rem_10rem_auto] md:items-end" do |form| %>
      <div>
        <%= form.label :q, "Search attendance sheet", class: "form-label" %>
        <%= form.search_field :q, value: @search_query, placeholder: "Name or email", class: "form-input" %>
      </div>
      <div>
        <%= form.label :rsvp, "RSVP", class: "form-label" %>
        <%= form.select :rsvp, options_for_select([["All responses", ""], ["Attending", "attending"], ["Maybe", "maybe"], ["Not attending", "not_attending"], ["No response", "no_response"]], @rsvp_filter), {}, class: "form-input" %>
      </div>
      <div>
        <%= form.label :attendance, "Attendance", class: "form-label" %>
        <%= form.select :attendance, options_for_select([["All records", ""]] + AttendanceRecord::STATUSES.map { |status| [status.humanize, status] } + [["Unmarked", "unmarked"]], @attendance_filter), {}, class: "form-input" %>
      </div>
      <%= form.submit "Filter sheet", class: "button-primary" %>
    <% end %>
    <% if @search_query.present? || @rsvp_filter.present? || @attendance_filter.present? %>
      <p class="mt-3 text-sm"><%= link_to "Clear filters", organization_event_attendance_path(@organization, @event), class: "text-link" %></p>
    <% end %>
  </section>

  <section class="workspace-section" aria-labelledby="attendance-roster">
    <div class="workspace-section-heading">
      <p class="eyebrow">Attendance</p>
      <h2 id="attendance-roster" class="mt-1 text-2xl font-semibold">Event roster</h2>
    </div>

    <% if @event.attendance_records.none? %>
      <p class="mt-5 border-l-4 border-amber bg-amber-pale/35 px-4 py-3 text-sm text-ink-soft">No attendance has been recorded yet. Use the roster below to mark attendance.</p>
    <% end %>

    <% if @memberships.any? %>
    <div class="mt-6 divide-y divide-rule border-y border-rule">
      <% @memberships.each do |membership| %>
        <% rsvp = @rsvps_by_membership_id[membership.id] %>
        <% attendance = @attendance_by_membership_id[membership.id] %>
        <%= turbo_frame_tag "attendance-member-#{membership.id}", class: "block scroll-mt-4" do %>
          <article class="member-row items-start py-4">
            <div class="min-w-0 flex-1">
              <h3 class="font-semibold"><%= membership.user.name %></h3>
              <p class="mt-1 text-xs text-ink-soft"><%= membership.user.email_address %> · <%= membership.role.humanize %></p>
              <p class="mt-3 text-xs font-bold text-ink-soft">RSVP <span class="role-tag ml-1"><%= rsvp&.status&.humanize || "No response" %></span></p>
              <% if attendance&.checked_in_at %><p class="mt-1 text-xs text-ink-soft">Checked in <%= attendance.checked_in_at.strftime("%-I:%M %p") %></p><% end %>
              <% if attendance&.marked_by %><p class="mt-1 text-xs text-ink-soft">Marked by <%= attendance.marked_by.name %> · updated <%= attendance.updated_at.strftime("%b %-d at %-I:%M %p") %></p><% end %>
              <% if attendance&.note.present? %><p class="mt-2 text-sm text-ink-soft"><%= attendance.note %></p><% end %>
            </div>
            <div class="w-full sm:w-auto sm:max-w-md">
              <p class="text-xs font-bold uppercase tracking-wide text-ink-soft">Attendance</p>
              <span class="role-tag"><%= attendance&.status&.humanize || "Not marked" %></span>
              <% if turbo_frame_request? && flash[:notice] %><p class="mt-2 text-xs font-bold text-moss-dark"><%= flash[:notice] %></p><% end %>
              <%= form_with url: organization_event_attendance_record_path(@organization, @event, membership), method: :patch, scope: :attendance_record, class: "mt-3" do |form| %>
                <% request.query_parameters.slice("q", "rsvp", "attendance", "page").each do |key, value| %>
                  <%= hidden_field_tag key, value %>
                <% end %>
                <%= form.label :note, "Note for #{membership.user.name}", class: "form-label text-xs" %>
                <%= form.text_field :note, value: attendance&.note, maxlength: 1000, placeholder: "Optional note", class: "form-input text-sm" %>
                <fieldset class="mt-3">
                  <legend class="text-xs font-bold text-ink-soft">Mark attendance</legend>
                  <div class="mt-2 flex flex-wrap gap-2">
                    <% AttendanceRecord::STATUSES.each do |status| %>
                      <%= form.button status.humanize, name: "attendance_record[status]", value: status, class: status == attendance&.status ? "button-primary" : "button-secondary" %>
                    <% end %>
                  </div>
                </fieldset>
              <% end %>
            </div>
          </article>
        <% end %>
      <% end %>
    </div>
    <%= render "shared/pagination", paginator: @paginator %>
    <% else %>
      <div class="mt-6 border-l-4 border-amber bg-amber-pale/35 px-4 py-3">
        <p class="font-bold">No members match those filters.</p>
        <p class="mt-1 text-sm text-ink-soft">Try another name, email, RSVP, or attendance status.</p>
      </div>
    <% end %>
  </section>
</article>
