<% content_for :title, "Import roster · #{@organization.name} · Tabled" %>

<article class="binder-page mx-auto w-full max-w-4xl">
  <div class="document-meta">
    <span><%= link_to @organization.name, organization_path(@organization), class: "text-link" %></span>
    <span><%= link_to "Member roster", organization_members_path(@organization), class: "text-link" %></span>
    <span>Roster import</span>
  </div>

  <header class="border-b-2 border-ink/20 px-5 py-6 sm:px-8">
    <p class="eyebrow">Import roster</p>
    <h1 class="mt-2 text-3xl font-semibold sm:text-4xl">Import roster</h1>
    <p class="mt-2 max-w-2xl text-sm leading-6 text-ink-soft">Upload a CSV with name, email, and role. Valid rows create pending invitations; emails are not sent automatically.</p>
  </header>

  <section class="p-5 sm:p-8">
    <%= form_with url: organization_roster_import_path(@organization), scope: :roster_import, multipart: true, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :csv_file, "Roster CSV", class: "form-label" %>
        <%= form.file_field :csv_file, accept: ".csv,text/csv", required: true, class: "form-input" %>
        <p class="mt-2 text-xs leading-5 text-ink-soft">Expected columns: <span class="font-bold">name</span>, <span class="font-bold">email</span>, <span class="font-bold">role</span>. Role defaults to member when blank. Owner rows are rejected.</p>
      </div>

      <div class="border-l-4 border-amber bg-amber-pale/35 px-4 py-3 text-sm leading-6 text-ink-soft">
        Rows that already belong to the organization or already have a pending invitation will be skipped.
      </div>

      <div class="flex flex-wrap gap-3">
        <%= form.submit "Import roster", class: "button-primary" %>
        <%= link_to "Back to member roster", organization_members_path(@organization), class: "button-secondary" %>
      </div>
    <% end %>
  </section>

  <% if @result %>
    <section class="border-t border-rule p-5 sm:p-8" aria-labelledby="import-results">
      <div class="workspace-section-heading">
        <p class="eyebrow">Review rows</p>
        <h2 id="import-results" class="mt-1 text-2xl font-semibold">Import results</h2>
      </div>

      <p class="mt-4 text-sm leading-6 text-ink-soft">
        <%= pluralize(@result.created_count, "invitation") %> created ·
        <%= pluralize(@result.skipped_count, "row") %> skipped ·
        <%= pluralize(@result.invalid_count, "row") %> invalid
      </p>

      <div class="mt-6 overflow-x-auto">
        <table class="w-full min-w-[46rem] border-collapse text-left text-sm">
          <thead>
            <tr class="border-b-2 border-ink/20 text-xs text-ink-soft">
              <th scope="col" class="px-3 py-3 font-bold">Row</th>
              <th scope="col" class="px-3 py-3 font-bold">Name</th>
              <th scope="col" class="px-3 py-3 font-bold">Email</th>
              <th scope="col" class="px-3 py-3 font-bold">Role</th>
              <th scope="col" class="px-3 py-3 font-bold">Status</th>
              <th scope="col" class="px-3 py-3 font-bold">Note</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-rule/70">
            <% @result.rows.each do |row| %>
              <tr>
                <td class="px-3 py-4"><%= row.number %></td>
                <td class="px-3 py-4"><%= row.name.presence || "—" %></td>
                <td class="px-3 py-4"><%= row.email.presence || "—" %></td>
                <td class="px-3 py-4"><%= row.role.presence || "—" %></td>
                <td class="px-3 py-4"><span class="role-tag"><%= row.status.to_s.humanize %></span></td>
                <td class="px-3 py-4 text-ink-soft"><%= row.message %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
</article>
