<% content_for :title, "Semester report · #{@organization.name} · Tabled" %>

<article class="binder-page w-full">
  <div class="document-meta">
    <span><%= link_to @organization.name, organization_path(@organization), class: "text-link" %></span>
    <span>Officer records</span>
    <span>Current semester · <%= current_semester_label %></span>
  </div>

  <header class="flex flex-wrap items-end justify-between gap-5 border-b-2 border-ink/20 px-5 py-6 sm:px-8">
    <div>
      <p class="eyebrow">Semester record</p>
      <h1 class="mt-2 text-3xl font-semibold sm:text-4xl">Semester report</h1>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-ink-soft">A practical record of members, gatherings, and attendance.</p>
    </div>
    <div class="flex flex-wrap gap-3 text-sm" aria-label="Export records">
      <%= link_to "Download roster CSV", roster_organization_reports_path(@organization, format: :csv), class: "button-secondary" %>
      <%= link_to "Download participation CSV", participation_organization_reports_path(@organization, format: :csv), class: "button-secondary" %>
      <%= link_to "Download event summary CSV", events_organization_reports_path(@organization, format: :csv), class: "button-secondary" %>
    </div>
  </header>

  <% if @report.empty? %>
    <section class="workspace-section">
      <div class="border-l-4 border-amber bg-amber-pale/35 px-4 py-3">
        <p class="font-bold">No semester record yet.</p>
        <p class="mt-1 text-sm text-ink-soft">Reports will fill in as events, RSVPs, and attendance are recorded.</p>
      </div>
    </section>
  <% else %>
    <section class="workspace-section" aria-labelledby="report-summary">
      <div class="workspace-section-heading">
        <p class="eyebrow">Record summary</p>
        <h2 id="report-summary" class="mt-1 text-2xl font-semibold">Current semester</h2>
      </div>

      <dl class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div class="border border-rule bg-sheet p-4">
          <dt class="text-xs font-bold uppercase tracking-wide text-ink-soft">Current members</dt>
          <dd class="mt-2 font-serif text-3xl font-semibold"><%= @report.total_members %></dd>
        </div>
        <div class="border border-rule bg-sheet p-4">
          <dt class="text-xs font-bold uppercase tracking-wide text-ink-soft">Gatherings held</dt>
          <dd class="mt-2 font-serif text-3xl font-semibold"><%= @report.events_held %></dd>
        </div>
        <div class="border border-rule bg-sheet p-4">
          <dt class="text-xs font-bold uppercase tracking-wide text-ink-soft">Attendance recorded</dt>
          <dd class="mt-2 font-serif text-3xl font-semibold"><%= @report.events_with_attendance_recorded %></dd>
        </div>
        <div class="border border-rule bg-sheet p-4">
          <dt class="text-xs font-bold uppercase tracking-wide text-ink-soft">Upcoming gatherings</dt>
          <dd class="mt-2 font-serif text-3xl font-semibold"><%= @report.upcoming_events %></dd>
        </div>
        <div class="border border-rule bg-sheet p-4">
          <dt class="text-xs font-bold uppercase tracking-wide text-ink-soft">Published bulletin posts</dt>
          <dd class="mt-2 font-serif text-3xl font-semibold"><%= @report.published_announcements %></dd>
        </div>
        <div class="border border-rule bg-sheet p-4">
          <dt class="text-xs font-bold uppercase tracking-wide text-ink-soft">Open onboarding</dt>
          <dd class="mt-2 text-sm leading-6"><%= pluralize(@report.pending_invitations, "pending invitation") %> · <%= pluralize(@report.active_recruitment_links, "active recruitment link") %></dd>
        </div>
      </dl>
    </section>

    <section class="workspace-section" aria-labelledby="attendance-summary">
      <div class="workspace-section-heading">
        <p class="eyebrow">Attendance summary</p>
        <h2 id="attendance-summary" class="mt-1 text-2xl font-semibold">Recorded participation</h2>
      </div>

      <% if @report.events_with_attendance_recorded.positive? %>
        <dl class="mt-6 grid gap-4 sm:grid-cols-4">
          <% AttendanceRecord::STATUSES.each do |status| %>
            <div class="border border-rule bg-sheet p-4">
              <dt class="text-xs font-bold uppercase tracking-wide text-ink-soft"><%= status.humanize %></dt>
              <dd class="mt-2 font-serif text-3xl font-semibold"><%= @report.attendance_count(status) %></dd>
            </div>
          <% end %>
        </dl>
      <% else %>
        <p class="mt-5 border-l-4 border-amber bg-amber-pale/35 px-4 py-3 text-sm text-ink-soft">No attendance has been recorded yet.</p>
      <% end %>
    </section>

    <section class="workspace-section" aria-labelledby="member-participation">
      <div class="workspace-section-heading">
        <p class="eyebrow">Member participation</p>
        <h2 id="member-participation" class="mt-1 text-2xl font-semibold">Participation record</h2>
      </div>

      <div class="mt-6 overflow-x-auto">
        <table class="w-full min-w-[56rem] border-collapse text-left text-sm">
          <thead>
            <tr class="border-b-2 border-ink/20 text-xs text-ink-soft">
              <th scope="col" class="px-3 py-3 font-bold">Member</th>
              <th scope="col" class="px-3 py-3 font-bold">Role</th>
              <th scope="col" class="px-3 py-3 font-bold">RSVP attending</th>
              <th scope="col" class="px-3 py-3 font-bold">Attended</th>
              <th scope="col" class="px-3 py-3 font-bold">Late</th>
              <th scope="col" class="px-3 py-3 font-bold">Excused</th>
              <th scope="col" class="px-3 py-3 font-bold">Absent</th>
              <th scope="col" class="px-3 py-3 font-bold">Last attended</th>
              <th scope="col" class="px-3 py-3 font-bold">Attendance rate</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-rule/70">
            <% @member_participation_rows.each do |row| %>
              <tr>
                <th scope="row" class="px-3 py-4">
                  <span class="font-bold text-ink"><%= row.user.name %></span>
                  <span class="mt-1 block text-xs font-normal text-ink-soft"><%= row.user.email_address %></span>
                </th>
                <td class="px-3 py-4"><span class="role-tag"><%= row.membership.role.humanize %></span></td>
                <td class="px-3 py-4"><%= row.rsvp_attending_count %></td>
                <td class="px-3 py-4"><%= row.attended_count %></td>
                <td class="px-3 py-4"><%= row.late_count %></td>
                <td class="px-3 py-4"><%= row.excused_count %></td>
                <td class="px-3 py-4"><%= row.absent_count %></td>
                <td class="px-3 py-4 text-ink-soft">
                  <% if row.last_attended_record %>
                    <%= row.last_attended_record.event.title %><br>
                    <span class="text-xs"><%= row.last_attended_record.event.starts_at.to_date.to_fs(:long) %></span>
                  <% else %>
                    Not recorded
                  <% end %>
                </td>
                <td class="px-3 py-4"><%= row.attendance_rate_label %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <%= render "shared/pagination", paginator: @member_participation_paginator, anchor: "member-participation" %>
    </section>

    <section class="workspace-section" aria-labelledby="event-summary">
      <div class="workspace-section-heading">
        <p class="eyebrow">Event summary</p>
        <h2 id="event-summary" class="mt-1 text-2xl font-semibold">Held gatherings</h2>
      </div>

      <% if @report.event_summaries.any? %>
        <div class="mt-6 overflow-x-auto">
          <table class="w-full min-w-[52rem] border-collapse text-left text-sm">
            <thead>
              <tr class="border-b-2 border-ink/20 text-xs text-ink-soft">
                <th scope="col" class="px-3 py-3 font-bold">Gathering</th>
                <th scope="col" class="px-3 py-3 font-bold">Date</th>
                <th scope="col" class="px-3 py-3 font-bold">RSVPs</th>
                <th scope="col" class="px-3 py-3 font-bold">Present</th>
                <th scope="col" class="px-3 py-3 font-bold">Late</th>
                <th scope="col" class="px-3 py-3 font-bold">Excused</th>
                <th scope="col" class="px-3 py-3 font-bold">Absent</th>
                <th scope="col" class="px-3 py-3 font-bold">Recorded?</th>
                <th scope="col" class="px-3 py-3 font-bold">Capacity</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-rule/70">
              <% @report.event_summaries.each do |row| %>
                <tr>
                  <th scope="row" class="px-3 py-4 font-bold text-ink"><%= link_to row.event.title, organization_event_path(@organization, row.event), class: "text-link" %></th>
                  <td class="px-3 py-4 text-ink-soft"><%= row.event.starts_at.to_date.to_fs(:long) %></td>
                  <td class="px-3 py-4"><%= row.rsvp_attending_count %></td>
                  <td class="px-3 py-4"><%= row.present_count %></td>
                  <td class="px-3 py-4"><%= row.late_count %></td>
                  <td class="px-3 py-4"><%= row.excused_count %></td>
                  <td class="px-3 py-4"><%= row.absent_count %></td>
                  <td class="px-3 py-4"><%= row.attendance_recorded? ? "Yes" : "No" %></td>
                  <td class="px-3 py-4 text-ink-soft"><%= row.capacity_usage || "No capacity" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="mt-5 border-l-4 border-amber bg-amber-pale/35 px-4 py-3 text-sm text-ink-soft">No past gatherings yet.</p>
      <% end %>
    </section>
  <% end %>
</article>
