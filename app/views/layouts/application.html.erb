<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tabled" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tabled">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-paper font-sans text-ink antialiased">
    <header class="border-b-2 border-ink/20 bg-paper-deep">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-5 px-5 py-3">
        <%= link_to root_path, class: "flex items-baseline gap-2" do %>
          <span class="font-serif text-2xl font-bold tracking-tight">Tabled</span>
          <span class="hidden text-xs font-semibold text-ink-soft sm:inline">for student organizations</span>
        <% end %>
        <% if authenticated? %>
          <div class="flex min-w-0 items-center gap-3 text-sm sm:gap-4">
            <span class="max-w-32 truncate border-b border-rule pb-0.5 text-ink-soft sm:max-w-48"><%= current_user.name %></span>
            <%= link_to "Account settings", account_settings_path, class: "whitespace-nowrap font-bold text-moss-dark underline decoration-moss/40 underline-offset-4 focus:outline-2 focus:outline-offset-2 focus:outline-moss/50" %>
            <%= button_to "Sign out", session_path, method: :delete, class: "cursor-pointer whitespace-nowrap font-bold text-moss-dark underline decoration-moss/40 underline-offset-4 focus:outline-2 focus:outline-offset-2 focus:outline-moss/50" %>
          </div>
        <% end %>
      </div>
      <% if authenticated? && current_user.organizations.active.any? %>
        <nav aria-label="Your organizations" class="border-t border-rule bg-paper">
          <div class="mx-auto flex max-w-6xl items-end gap-1 overflow-x-auto px-5 pt-2 text-sm">
            <span class="mr-3 shrink-0 pb-2 text-xs font-semibold text-ink-soft">Your organizations</span>
            <% current_user.organizations.active.order(:name).each do |organization| %>
              <%= link_to organization.name, organization_path(organization), aria: { current: ("page" if @organization == organization) }, class: "shrink-0 border-x border-t px-3 py-2 font-bold focus:outline-2 focus:outline-offset-[-2px] focus:outline-moss/50 #{"border-rule bg-sheet text-ink" if @organization == organization} #{"border-transparent text-ink-soft hover:border-rule" unless @organization == organization}" %>
            <% end %>
            <%= link_to "+ New organization", new_organization_path, class: "ml-2 shrink-0 pb-2 font-bold text-moss-dark underline decoration-moss/35 underline-offset-4 focus:outline-2 focus:outline-moss/50" %>
          </div>
        </nav>
      <% end %>
    </header>

    <% if flash.any? %>
      <div class="mx-auto max-w-6xl px-5 pt-5">
        <% flash.each do |type, message| %>
          <div class="flash-note <%= type == "alert" ? "flash-alert" : "flash-notice" %>" role="<%= type == "alert" ? "alert" : "status" %>">
            <%= message %>
          </div>
        <% end %>
      </div>
    <% end %>

    <main class="mx-auto flex min-h-[calc(100vh-74px)] max-w-6xl items-start justify-center px-5 py-8 sm:py-10">
      <%= yield %>
    </main>
  </body>
</html>
