<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tabled" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Tabled">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-paper font-sans text-ink antialiased">
    <header class="border-b-2 border-ink/20 bg-paper-deep">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-5 px-5 py-3">
        <%= link_to root_path, class: "flex items-baseline gap-2" do %>
          <span class="font-serif text-2xl font-bold tracking-tight">Tabled</span>
          <span class="hidden text-[0.65rem] font-bold uppercase tracking-[0.14em] text-ink-soft sm:inline">organization book</span>
        <% end %>
        <% if authenticated? %>
          <div class="flex items-center gap-4 text-sm">
            <span class="hidden border-b border-rule pb-0.5 text-ink-soft sm:inline"><%= current_user.name %></span>
            <%= button_to "Sign out", session_path, method: :delete, class: "cursor-pointer font-bold text-moss-dark underline decoration-moss/40 underline-offset-4" %>
          </div>
        <% end %>
      </div>
      <% if authenticated? && current_user.organizations.any? %>
        <nav aria-label="Your organizations" class="border-t border-rule bg-paper">
          <div class="mx-auto flex max-w-6xl items-end gap-1 overflow-x-auto px-5 pt-2 text-sm">
            <span class="mr-3 shrink-0 pb-2 text-[0.65rem] font-bold uppercase tracking-[0.12em] text-ink-soft">Organization file</span>
            <% current_user.organizations.order(:name).each do |organization| %>
              <%= link_to organization.name, organization_path(organization), class: "shrink-0 border-x border-t px-3 py-2 font-bold #{"border-rule bg-sheet text-ink" if @organization == organization} #{"border-transparent text-ink-soft hover:border-rule" unless @organization == organization}" %>
            <% end %>
            <%= link_to "+ Add organization", new_organization_path, class: "ml-2 shrink-0 pb-2 font-bold text-moss-dark" %>
          </div>
        </nav>
      <% end %>
    </header>

    <% if flash.any? %>
      <div class="mx-auto max-w-3xl px-5 pt-5">
        <% flash.each do |type, message| %>
          <div class="border-l-4 px-4 py-3 text-sm <%= type == "alert" ? "border-brick bg-brick-pale text-brick" : "border-moss bg-olive-pale text-moss-dark" %>"><%= message %></div>
        <% end %>
      </div>
    <% end %>

    <main class="mx-auto flex min-h-[calc(100vh-74px)] max-w-6xl items-start justify-center px-5 py-8 sm:py-10">
      <%= yield %>
    </main>
  </body>
</html>
