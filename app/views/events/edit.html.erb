<% content_for :title, "Edit #{@event.title} · #{@organization.name} · Tabled" %>

<section class="binder-page w-full max-w-3xl">
  <div class="document-meta">
    <span><%= link_to @organization.name, organization_path(@organization), class: "text-link" %></span>
    <span><%= link_to "Gatherings", organization_events_path(@organization), class: "text-link" %></span>
    <span><%= link_to @event.title, organization_event_path(@organization, @event), class: "text-link" %></span>
  </div>
  <div class="p-6 sm:p-9">
    <h1 class="mt-2 text-3xl font-semibold">Edit gathering</h1>
    <p class="mt-2 max-w-xl text-sm leading-6 text-ink-soft">Keep the details current for everyone planning to attend.</p>
    <%= render "form", organization: @organization, event: @event %>
  </div>
</section>
