<% content_for :title, "#{@event.title} · #{@organization.name} · Tabled" %>

<article class="binder-page w-full">
  <div class="document-meta">
    <span><%= link_to @organization.name, organization_path(@organization), class: "text-link" %></span>
    <span><%= link_to "Gatherings", organization_events_path(@organization), class: "text-link" %></span>
    <span><%= @event.upcoming? ? "Upcoming" : "Past gathering" %></span>
  </div>

  <header class="border-b-2 border-ink/20 px-5 py-6 sm:px-8">
    <div class="flex flex-wrap items-start justify-between gap-5">
      <div>
        <p class="eyebrow"><%= @event.starts_at.strftime("%A, %B %-d") %></p>
        <h1 class="mt-2 max-w-4xl text-3xl font-semibold sm:text-4xl"><%= @event.title %></h1>
        <p class="mt-3 text-sm text-ink-soft">Hosted by <%= @event.created_by.name %></p>
      </div>
      <% if @event_policy.update? || @event_policy.destroy? %>
        <div aria-label="Organizer tools">
          <p class="eyebrow text-right">Organizer tools</p>
          <div class="mt-2 flex flex-wrap items-center justify-end gap-2">
            <% if @event_policy.manage_attendance? %><%= link_to "Attendance sheet", organization_event_attendance_path(@organization, @event), class: "button-secondary" %><% end %>
            <% if @event_policy.update? %><%= link_to "Edit gathering", edit_organization_event_path(@organization, @event), class: "button-secondary" %><% end %>
            <% if @event_policy.destroy? %>
              <div class="ml-1 border-l border-rule pl-3">
                <%= button_to "Remove gathering", organization_event_path(@organization, @event), method: :delete, class: "cursor-pointer text-sm font-bold text-brick underline decoration-brick/40 underline-offset-4", form: { data: { turbo_confirm: "Remove #{@event.title} from the calendar?" } } %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </header>

  <div class="lg:grid lg:grid-cols-[1fr_19rem]">
    <div class="divide-y divide-rule lg:border-r lg:border-rule">
      <section class="workspace-section" aria-labelledby="gathering-details">
        <div class="workspace-section-heading">
          <p class="eyebrow">On the calendar</p>
          <h2 id="gathering-details" class="mt-1 text-2xl font-semibold">Gathering details</h2>
        </div>

        <dl class="mt-6 grid gap-x-8 gap-y-5 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-bold text-moss-dark">Starts</dt>
            <dd class="mt-1 leading-6"><time datetime="<%= @event.starts_at.iso8601 %>"><%= @event.starts_at.strftime("%A, %B %-d at %-I:%M %p") %></time></dd>
          </div>
          <% if @event.ends_at.present? %>
            <div>
              <dt class="text-sm font-bold text-moss-dark">Ends</dt>
              <dd class="mt-1 leading-6"><time datetime="<%= @event.ends_at.iso8601 %>"><%= @event.ends_at.strftime("%A, %B %-d at %-I:%M %p") %></time></dd>
            </div>
          <% end %>
          <% if @event.location.present? %>
            <div>
              <dt class="text-sm font-bold text-moss-dark">Location</dt>
              <dd class="mt-1 leading-6"><%= @event.location %></dd>
            </div>
          <% end %>
          <% if @event.capacity.present? %>
            <div>
              <dt class="text-sm font-bold text-moss-dark">Capacity</dt>
              <dd class="mt-1 leading-6"><%= pluralize(@event.capacity, "spot") %></dd>
            </div>
          <% end %>
          <% if @event.rsvp_deadline.present? %>
            <div>
              <dt class="text-sm font-bold text-moss-dark">RSVPs close</dt>
              <dd class="mt-1 leading-6"><time datetime="<%= @event.rsvp_deadline.iso8601 %>"><%= @event.rsvp_deadline.strftime("%A, %B %-d at %-I:%M %p") %></time></dd>
            </div>
          <% end %>
        </dl>

        <% if @event.description.present? %>
          <div class="mt-7 border-t border-rule pt-5">
            <h3 class="text-lg font-semibold">Notes for members</h3>
            <div class="mt-2 whitespace-pre-line leading-7 text-ink-soft"><%= @event.description %></div>
          </div>
        <% end %>
      </section>

      <section class="workspace-section" aria-labelledby="your-rsvp">
        <div class="workspace-section-heading">
          <p class="eyebrow">Before the gathering</p>
          <h2 id="your-rsvp" class="mt-1 text-2xl font-semibold">Your RSVP</h2>
        </div>
        <p class="mt-4 text-sm leading-6 text-ink-soft">Are you planning to come?</p>
        <% if @rsvp %>
          <p class="mt-3">You answered <span class="role-tag"><%= @rsvp.status.humanize %></span></p>
        <% else %>
          <p class="mt-3 text-sm leading-6 text-ink-soft">Let the organizers know whether you plan to come.</p>
        <% end %>

        <% rsvps_closed = @event.rsvp_deadline_passed? && !@event_policy.override_rsvp_limits? %>
        <% if rsvps_closed %>
          <p class="mt-4 font-bold text-brick">RSVPs are closed.</p>
        <% else %>
          <%= form_with model: (@rsvp || @event.rsvps.new), url: organization_event_rsvp_path(@organization, @event), method: @rsvp ? :patch : :post, class: "mt-5" do |form| %>
            <fieldset>
              <legend class="sr-only">Choose your RSVP for <%= @event.title %></legend>
              <div class="flex flex-wrap gap-3">
                <%= form.button "I’m attending", name: "rsvp[status]", value: "attending", class: "button-primary", disabled: @event.full? && !@rsvp&.attending? && !@event_policy.override_rsvp_limits? %>
                <%= form.button "Maybe", name: "rsvp[status]", value: "maybe", class: "button-secondary" %>
                <%= form.button "I can’t make it", name: "rsvp[status]", value: "not_attending", class: "button-secondary" %>
              </div>
            </fieldset>
          <% end %>
          <% if @event.full? && !@rsvp&.attending? && !@event_policy.override_rsvp_limits? %>
            <p class="mt-3 text-sm font-bold text-brick">This gathering is full, but you can still answer maybe or not attending.</p>
          <% end %>
        <% end %>
      </section>

      <section class="workspace-section" aria-labelledby="member-check-in">
        <div class="workspace-section-heading">
          <p class="eyebrow">During the gathering</p>
          <h2 id="member-check-in" class="mt-1 text-2xl font-semibold">Member check-in</h2>
        </div>
        <p class="mt-4 text-sm leading-6 text-ink-soft">Use this during the gathering to record that you were there.</p>

        <% if @attendance_record %>
          <p class="mt-3">Attendance: <span class="role-tag"><%= @attendance_record.status.humanize %></span></p>
          <% if @attendance_record.checked_in_at %><p class="mt-2 text-sm text-ink-soft">Checked in <%= @attendance_record.checked_in_at.strftime("%B %-d at %-I:%M %p") %>.</p><% end %>
        <% end %>

        <% if @event.check_in_open? %>
          <p class="mt-3 text-sm leading-6 text-ink-soft">Enter the code shared at the gathering.</p>
          <%= form_with url: organization_event_check_in_path(@organization, @event), class: "mt-4 flex max-w-md flex-wrap items-end gap-3" do |form| %>
            <div class="min-w-48 flex-1">
              <%= form.label :check_in_code, "Check-in code", class: "form-label" %>
              <%= form.text_field :check_in_code, required: true, maxlength: 12, autocomplete: "off", class: "form-input uppercase", placeholder: "Six-character code" %>
            </div>
            <%= form.submit "Check in", class: "button-primary" %>
          <% end %>
        <% elsif @event.check_in_state == :closed %>
          <p class="mt-5 text-sm font-bold text-brick">Check-in has closed for this gathering.</p>
        <% else %>
          <p class="mt-5 text-sm text-ink-soft"><strong class="text-ink">Check-in not started.</strong> Your organizer will share a code when the gathering begins.</p>
        <% end %>
      </section>
    </div>

    <aside class="border-t-2 border-ink/15 bg-paper-deep/35 lg:border-t-0">
      <section class="p-5 sm:p-6">
        <p class="eyebrow text-amber">RSVPs</p>
        <h2 class="mt-1 text-xl font-semibold">RSVP summary</h2>
        <p class="mt-4 font-serif text-3xl font-semibold"><%= @event.attending_count %></p>
        <p class="text-sm text-ink-soft"><%= "member".pluralize(@event.attending_count) %> attending<% if @event.capacity.present? %> of <%= @event.capacity %> spots<% end %></p>
        <% if @event.full? %><p class="form-note mt-4">This gathering is full.</p><% end %>
        <% if @event.rsvp_deadline_passed? %><p class="mt-4 text-sm font-bold text-brick">RSVPs are closed.</p><% end %>
        <% if @event_policy.view_roster? %>
          <dl class="mt-5 grid grid-cols-3 gap-2 border-y border-rule py-4 text-center">
            <% [["Attending", "attending"], ["Maybe", "maybe"], ["Not attending", "not_attending"]].each do |label, status| %>
              <div>
                <dt class="text-xs font-bold text-ink-soft"><%= label %></dt>
                <dd class="mt-1 font-serif text-2xl font-semibold"><%= @rsvps_by_status.fetch(status, []).size %></dd>
              </div>
            <% end %>
          </dl>

          <div class="mt-6" aria-labelledby="event-roster">
            <h2 id="event-roster" class="text-xl font-semibold">Event roster</h2>
            <div class="mt-4 divide-y divide-rule border-y border-rule">
              <% [["Attending", "attending"], ["Not attending", "not_attending"], ["Maybe", "maybe"]].each do |label, status| %>
                <% responses = @rsvps_by_status.fetch(status, []) %>
                <details class="py-3">
                  <summary id="roster-<%= status %>" class="cursor-pointer list-none text-sm font-bold text-moss-dark underline decoration-moss/30 underline-offset-4 focus:outline-2 focus:outline-moss/50">
                    <%= label %> · <%= pluralize(responses.size, "member") %>
                  </summary>
                  <% if responses.any? %>
                    <ul class="mt-3 divide-y divide-rule/70 border-y border-rule text-sm">
                      <% responses.sort_by { |response| response.membership.user.name.downcase }.each do |response| %>
                        <li class="py-2"><%= response.membership.user.name %></li>
                      <% end %>
                    </ul>
                  <% else %>
                    <p class="mt-3 text-sm text-ink-soft">No responses yet.</p>
                  <% end %>
                </details>
              <% end %>
            </div>
          </div>
        <% end %>
      </section>

      <% unless @event_policy.view_roster? %>
        <section id="member-attendees" class="border-t border-rule p-5 sm:p-6" aria-labelledby="member-attendees-heading">
          <p class="eyebrow text-moss-dark">Attendees</p>
          <h2 id="member-attendees-heading" class="mt-1 text-xl font-semibold">Who’s coming</h2>
          <% if @visible_attending_rsvps.any? %>
            <ul class="mt-4 divide-y divide-rule/70 border-y border-rule text-sm">
              <% @visible_attending_rsvps.each do |response| %>
                <li class="py-2"><%= response.membership.user.name %></li>
              <% end %>
            </ul>
            <% if @additional_attendee_count.positive? %>
              <p class="mt-3 text-xs font-bold text-ink-soft">and <%= pluralize(@additional_attendee_count, "more member") %></p>
            <% end %>
          <% else %>
            <p class="mt-3 text-sm leading-6 text-ink-soft">No one has said they’re coming yet.</p>
          <% end %>
        </section>

        <section id="member-event-status" class="border-t border-rule p-5 sm:p-6" aria-labelledby="member-event-status-heading">
          <p class="eyebrow text-amber">Your record</p>
          <h2 id="member-event-status-heading" class="mt-1 text-xl font-semibold">Your status</h2>
          <dl class="mt-4 space-y-4 text-sm">
            <div>
              <dt class="font-bold text-moss-dark">RSVP</dt>
              <% if @rsvp %>
                <dd class="mt-1"><%= @rsvp.status.humanize %></dd>
              <% else %>
                <dd class="mt-1 text-ink-soft">You haven’t answered yet.</dd>
              <% end %>
            </div>
            <div>
              <dt class="font-bold text-moss-dark">Attendance</dt>
              <% if @attendance_record %>
                <dd class="mt-1"><%= @attendance_record.status.humanize %></dd>
                <% if @attendance_record.checked_in_at %>
                  <dd class="mt-1 text-xs leading-5 text-ink-soft">Checked in <%= @attendance_record.checked_in_at.strftime("%B %-d at %-I:%M %p") %>.</dd>
                <% end %>
              <% else %>
                <dd class="mt-1 text-ink-soft">You haven’t checked in yet.</dd>
              <% end %>
            </div>
          </dl>
        </section>

        <section id="member-check-in-guidance" class="border-t border-rule p-5 sm:p-6" aria-labelledby="member-check-in-guidance-heading">
          <p class="eyebrow text-brick">At the gathering</p>
          <h2 id="member-check-in-guidance-heading" class="mt-1 text-xl font-semibold">Check-in</h2>
          <% if @attendance_record&.present? || @attendance_record&.late? %>
            <p class="mt-3 text-sm font-bold text-moss-dark">You’re checked in.</p>
          <% elsif @event.check_in_open? %>
            <p class="mt-3 text-sm leading-6 text-ink-soft">Enter the shared code to mark that you’re here.</p>
          <% elsif @event.check_in_state == :closed %>
            <p class="mt-3 text-sm leading-6 text-ink-soft">Check-in has closed for this gathering.</p>
          <% else %>
            <p class="mt-3 text-sm leading-6 text-ink-soft">Your organizer will share a code when the gathering begins.</p>
          <% end %>
        </section>
      <% end %>

      <% if @event_policy.manage_attendance? %>
        <section class="border-t border-rule p-5 sm:p-6">
          <p class="eyebrow text-brick">Attendance</p>
          <h2 class="mt-1 text-xl font-semibold">
            <% if @event.check_in_open? %>
              Check-in is open
            <% elsif @event.check_in_state == :closed %>
              Check-in has closed
            <% else %>
              Check-in not started
            <% end %>
          </h2>

          <% if @attendance_counts.any? %>
            <% checked_in_count = @attendance_counts.fetch("present", 0) + @attendance_counts.fetch("late", 0) %>
            <% if @event.check_in_open? %><p class="mt-3 text-sm text-ink-soft"><%= pluralize(checked_in_count, "member") %> checked in.</p><% end %>
            <p class="mt-3 text-sm leading-6 text-ink-soft">
              <% AttendanceRecord::STATUSES.each_with_index do |status, index| %><%= " · " unless index.zero? %><strong class="text-ink"><%= status.humanize %></strong> <%= @attendance_counts.fetch(status, 0) %><% end %>
            </p>
          <% elsif @event.check_in_open? %>
            <p class="mt-3 text-sm text-ink-soft">No members have checked in yet.</p>
          <% else %>
            <p class="mt-3 text-sm text-ink-soft">Attendance has not been recorded yet.</p>
          <% end %>

          <% if flash[:check_in_code] %>
            <div class="mt-4 border-2 border-amber bg-amber-pale/45 p-4 text-center">
              <p class="text-xs font-bold uppercase tracking-wide text-ink-soft">Share this code</p>
              <p class="mt-1 font-mono text-3xl font-bold tracking-[0.2em]"><%= flash[:check_in_code] %></p>
              <p class="mt-2 text-xs text-ink-soft">It will not be shown again. Regenerate it if needed.</p>
            </div>
          <% end %>

          <p class="eyebrow mt-5">Check-in controls</p>
          <div class="mt-2 flex flex-wrap gap-2">
            <% if @event.check_in_open? %>
              <%= button_to "Close check-in", organization_event_check_in_settings_path(@organization, @event), method: :patch, params: { operation: "close" }, class: "button-secondary" %>
              <%= button_to "New code", organization_event_check_in_settings_path(@organization, @event), method: :patch, params: { operation: "regenerate" }, class: "button-secondary" %>
            <% else %>
              <%= button_to "Open check-in", organization_event_check_in_settings_path(@organization, @event), method: :patch, params: { operation: "open" }, class: "button-primary" %>
            <% end %>
          </div>
          <p class="mt-4 text-sm font-bold"><%= link_to "Open attendance sheet →", organization_event_attendance_path(@organization, @event), class: "text-link" %></p>
        </section>
      <% end %>
    </aside>
  </div>
</article>
