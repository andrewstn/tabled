<% content_for :title, "Members · #{@organization.name} · Tabled" %>

<article class="binder-page w-full">
  <div class="document-meta">
    <span><%= link_to @organization.name, organization_path(@organization), class: "text-link" %></span>
    <span>Current semester · <%= current_semester_label %></span>
  </div>

  <header class="flex flex-wrap items-end justify-between gap-5 border-b-2 border-ink/20 px-5 py-6 sm:px-8">
    <div>
      <p class="eyebrow">Members</p>
      <h1 class="mt-2 text-3xl font-semibold sm:text-4xl">Member roster</h1>
      <p class="mt-2 text-sm leading-6 text-ink-soft">Everyone currently around the table.</p>
    </div>
    <% if @can_manage_members %>
      <div class="flex flex-wrap gap-3 text-sm">
        <%= link_to "Invite member", new_organization_invitation_path(@organization), class: "button-primary" %>
        <%= link_to "Pending invitations (#{@pending_invitation_count})", organization_invitations_path(@organization), class: "button-secondary" %>
      </div>
    <% end %>
  </header>

  <div class="overflow-x-auto p-5 sm:p-8">
    <table class="w-full min-w-[42rem] border-collapse text-left text-sm">
      <thead>
        <tr class="border-b-2 border-ink/20 text-xs text-ink-soft">
          <th scope="col" class="px-3 py-3 font-bold">Member</th>
          <th scope="col" class="px-3 py-3 font-bold">Email</th>
          <th scope="col" class="px-3 py-3 font-bold">Role</th>
          <th scope="col" class="px-3 py-3 font-bold">Joined</th>
          <th scope="col" class="px-3 py-3 font-bold">Status</th>
          <% if @can_manage_members %><th scope="col" class="px-3 py-3 font-bold">Manage role</th><% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-rule/70">
        <% @memberships.each do |membership| %>
          <tr>
            <th scope="row" class="px-3 py-4 font-bold text-ink">
              <% history_policy = MembershipPolicy.new(current_user, @organization, membership) %>
              <% if history_policy.view_attendance_history? %>
                <%= link_to membership.user.name, organization_member_path(@organization, membership), class: "text-link" %>
              <% else %>
                <%= membership.user.name %>
              <% end %>
            </th>
            <td class="px-3 py-4 text-ink-soft"><%= membership.user.email_address %></td>
            <td class="px-3 py-4"><span class="role-tag"><%= membership.role.humanize %></span></td>
            <td class="px-3 py-4 text-ink-soft"><%= membership.created_at.to_date.to_fs(:long) %></td>
            <td class="px-3 py-4 text-ink-soft">Current</td>
            <% if @can_manage_members %>
              <td class="px-3 py-4">
                <% policy = MembershipPolicy.new(current_user, @organization, membership) %>
                <% if policy.permitted_roles.any? %>
                  <%= form_with model: membership, url: organization_member_path(@organization, membership), class: "flex items-center gap-2" do |form| %>
                    <%= form.label :role, "Role for #{membership.user.name}", class: "sr-only" %>
                    <%= form.select :role, options_for_select(policy.permitted_roles.map { |role| [ role.humanize, role ] }, membership.role), {}, class: "border border-rule bg-sheet px-2 py-1.5 text-sm focus:outline-2 focus:outline-offset-2 focus:outline-moss/50" %>
                    <%= form.submit "Update", class: "button-secondary" %>
                  <% end %>
                <% else %>
                  <span class="text-xs text-ink-soft">Managed by an owner</span>
                <% end %>
                <% if policy.remove? %>
                  <%= button_to "Remove", organization_member_path(@organization, membership), method: :delete,
                    class: "mt-2 text-xs font-bold text-brick underline decoration-brick/40 underline-offset-4",
                    form: { data: { turbo_confirm: "Remove #{membership.user.name} from #{@organization.name}? This removes them from the roster." } } %>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</article>
