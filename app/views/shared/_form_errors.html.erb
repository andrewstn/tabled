<% if record.errors.any? %>
  <div class="form-note" role="alert">
    <p class="font-semibold">Please check these details:</p>
    <ul class="mt-1 list-disc pl-5">
      <% record.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
