<% if record.errors.any? %>
  <div class="rounded-lg border border-brick/30 bg-brick/10 px-4 py-3 text-sm text-brick" role="alert">
    <p class="font-semibold">A few things need another look:</p>
    <ul class="mt-1 list-disc pl-5">
      <% record.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
