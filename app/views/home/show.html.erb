<% content_for :title, "Organizations · Tabled" %>

<section class="binder-page w-full max-w-4xl">
  <div class="document-meta">
    <span>Signed in as <%= current_user.name %></span>
    <span><%= current_semester_label %></span>
  </div>
  <div class="p-6 sm:p-9">
    <p class="eyebrow">Welcome, <%= current_user.name %></p>
    <h1 class="mt-2 text-3xl font-semibold">Your organizations</h1>

    <% if current_user.organizations.active.any? %>
      <p class="mt-2 text-sm text-ink-soft">Choose an organization to work in.</p>
      <nav aria-label="Organization workspaces" class="mt-7 border-t border-rule">
        <% current_user.organizations.active.order(:name).each do |organization| %>
          <%= link_to organization_path(organization), class: "organization-row" do %>
            <span class="font-bold"><%= organization.name %></span>
            <span class="flex items-center gap-3">
              <span class="role-tag"><%= current_user.memberships.find_by(organization: organization).role.humanize %></span>
              <span aria-hidden="true" class="text-moss-dark">→</span>
            </span>
          <% end %>
        <% end %>
      </nav>
      <div class="mt-7 border-t border-rule pt-5">
        <%= link_to "+ Add another organization", new_organization_path, class: "text-link text-sm" %>
      </div>
    <% else %>
      <div class="mt-7 border-y border-rule py-6">
        <p class="font-bold">No organizations yet.</p>
        <p class="mt-1 max-w-xl text-sm leading-6 text-ink-soft">If you help run a club, committee, or team, add it here. You’ll start as the owner.</p>
        <%= link_to "Add an organization", new_organization_path, class: "button-primary mt-5" %>
      </div>
    <% end %>
  </div>
</section>
