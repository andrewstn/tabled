<% content_for :title, "Organizations · Tabled" %>

<section class="binder-page w-full max-w-4xl">
  <div class="document-meta">
    <span>Member: <%= current_user.name %></span>
    <span>Your organizations</span>
  </div>
  <div class="p-6 sm:p-9">
    <p class="eyebrow">This semester</p>
    <h1 class="mt-2 text-3xl font-semibold">Welcome, <%= current_user.name %>.</h1>

    <% if current_user.organizations.any? %>
      <p class="mt-2 text-sm text-ink-soft">Choose an organization to work in.</p>
      <div class="ruled-list mt-7 border-t border-rule">
        <% current_user.organizations.order(:name).each do |organization| %>
          <%= link_to organization_path(organization), class: "flex min-h-[2.15rem] items-center justify-between gap-5 px-2 py-2 hover:bg-olive-pale/50" do %>
            <span class="font-bold"><%= organization.name %></span>
            <span class="text-xs font-bold uppercase tracking-wider text-ink-soft"><%= current_user.memberships.find_by(organization: organization).role %></span>
          <% end %>
        <% end %>
      </div>
      <div class="mt-7 border-t border-rule pt-5">
        <%= link_to "+ Add another organization", new_organization_path, class: "text-link text-sm" %>
      </div>
    <% else %>
      <div class="mt-7 border-y border-rule py-6">
        <p class="font-bold">Your organization index is empty.</p>
        <p class="mt-1 max-w-xl text-sm leading-6 text-ink-soft">If you help run a club, committee, or team, add its record here. You’ll be listed as the owner.</p>
        <%= link_to "Add an organization", new_organization_path, class: "button-primary mt-5" %>
      </div>
    <% end %>
  </div>
</section>
