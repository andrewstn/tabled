<% content_for :title, "Join · Tabled" %>

<div class="auth-card">
  <p class="eyebrow">Take a seat</p>
  <h1 class="auth-title">Make your place at the table.</h1>
  <p class="auth-copy">Start with your own account. Your organization workspace comes next.</p>

  <%= form_with model: @user, class: "mt-8 space-y-5" do |form| %>
    <%= render "shared/form_errors", record: @user %>
    <div>
      <%= form.label :name, "Your name", class: "form-label" %>
      <%= form.text_field :name, required: true, autofocus: true, autocomplete: "name", class: "form-input" %>
    </div>
    <div>
      <%= form.label :email_address, "Email address", class: "form-label" %>
      <%= form.email_field :email_address, required: true, autocomplete: "email", class: "form-input" %>
    </div>
    <div>
      <%= form.label :password, "Password (12 characters minimum)", class: "form-label" %>
      <%= form.password_field :password, required: true, minlength: 12, autocomplete: "new-password", class: "form-input" %>
    </div>
    <div>
      <%= form.label :password_confirmation, class: "form-label" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", class: "form-input" %>
    </div>
    <%= form.submit "Create my account", class: "button-primary w-full" %>
  <% end %>

  <p class="mt-6 text-sm text-ink-soft">Already have a seat? <%= link_to "Sign in", new_session_path, class: "text-link" %></p>
</div>
