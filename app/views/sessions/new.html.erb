<% content_for :title, "Sign in · Tabled" %>

<section class="auth-sheet">
  <%= render "shared/auth_meta", context: "Member access" %>

  <div class="md:grid md:grid-cols-[15rem_1fr]">
    <aside class="auth-note" aria-label="About member access">
      <p class="desk-label">Shared club workspace</p>
      <p class="mt-5 text-sm leading-6 text-ink-soft">Officers and members sign in here to keep up with the semester.</p>
      <ul class="mt-5 space-y-2 border-l-2 border-amber/60 pl-4 text-sm text-ink-soft">
        <li>Member rosters and roles</li>
        <li>Meetings and attendance</li>
        <li>Announcements and follow-up</li>
      </ul>
      <div class="mt-8 border-t border-rule pt-4 text-sm leading-6 text-ink-soft">
        <p class="font-bold text-ink">New to Tabled?</p>
        <%= link_to "Create your account →", new_user_path, class: "text-link mt-1 inline-block" %>
      </div>
      <div class="mt-6 border-t border-rule pt-4 text-sm leading-6 text-ink-soft">
        <p class="font-bold text-ink">Demo workspace</p>
        <p class="mt-1">Use the demo account to explore a populated organization workspace.</p>
        <dl class="mt-3 space-y-1 text-xs">
          <div>
            <dt class="inline font-bold text-ink">Email:</dt>
            <dd class="inline font-mono">demo-owner@example.test</dd>
          </div>
          <div>
            <dt class="inline font-bold text-ink">Password:</dt>
            <dd class="inline font-mono">tabled-demo-password</dd>
          </div>
        </dl>
      </div>
    </aside>

    <div class="auth-form">
      <%= render "shared/auth_heading",
        eyebrow: "Your organizations",
        title: "Member sign-in",
        description: "Open your organization workspace for rosters, meetings, announcements, and the work between them." %>

      <%= form_with url: session_path, class: "mt-8 max-w-xl space-y-6" do |form| %>
        <div>
          <%= form.label :email_address, "Member email", class: "form-label" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email", value: params[:email_address], aria: { describedby: "signin-email-hint" }, class: "form-input" %>
          <p id="signin-email-hint" class="mt-1.5 text-xs text-ink-soft">Use the email your organization knows you by.</p>
        </div>
        <div>
          <%= form.label :password, class: "form-label" %>
          <%= form.password_field :password, required: true, autocomplete: "current-password", class: "form-input" %>
        </div>
        <div class="border-t border-rule pt-5">
          <%= form.submit "Sign in", class: "button-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
